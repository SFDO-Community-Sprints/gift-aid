        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnectorLabel>Contact Found and GA Active</defaultConnectorLabel>
        <rules>
            <name>Contact_Found_and_not_GA</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
