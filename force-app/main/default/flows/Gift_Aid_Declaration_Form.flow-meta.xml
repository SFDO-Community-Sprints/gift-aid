        <rules>
            <name>Contact_Not_Found</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Exiting_Contact</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
